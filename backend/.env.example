# === Database ===
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/t2_schedule
# Docker Compose variant:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/t2_schedule

# === JWT / Auth ===
# Generate a strong random value in real env
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Schema management ===
# Keep false when using Alembic migrations
AUTO_CREATE_SCHEMA=false

# === CORS ===
# Comma-separated list of frontend origins allowed to call backend with credentials.
# Local Vite dev + current backend-hosting scenario:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === Email notifications ===
EMAIL_ENABLED=false
EMAIL_FROM=
EMAIL_FROM_NAME=T2 Schedule
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
FRONTEND_APP_URL=http://localhost:5173

# === Google Calendar integration ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback
GOOGLE_CALENDAR_SCOPES=openid email https://www.googleapis.com/auth/calendar.readonly
# Optional frontend redirect targets after OAuth callback:
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=
GOOGLE_OAUTH_ERROR_REDIRECT_URL=
